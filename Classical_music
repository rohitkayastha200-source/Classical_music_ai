    def generate(self) -> None:
        try:
            seed_str = self.seed_entry.get()
            length = int(self.length_entry.get())
            window = int(self.window_entry.get())
            chord_interval = int(self.chord_interval_entry.get())
            
            # Recreate AI with new window size if needed
            if window != self.ai.window:
                self.ai = MusicMemoryAI(num_neurons=256, window=window)
                corpus = build_training_corpus()
                train_model(self.ai, corpus)
            
            # Parse seed and generate
            seed = parse_seed(seed_str, window)
            generated = self.ai.generate(seed, length)
            self.last_generated_notes = generated
            
            # Detect chord progression from generated notes
            chord_progression = generate_chord_progression_from_seed(generated, chord_interval)
            chord_names = [f"{root}{chord_type[0].upper()}" for root, chord_type in chord_progression]
            
            # Display output
            output_text = f"Seed: {format_notes(seed)}\n"
            output_text += f"Generated: {format_notes(generated)}\n"
            output_text += f"\nDetected Chord Progression (interval={chord_interval}):\n"
            output_text += f"{' → '.join(chord_names)}\n"
            output_text += f"\nFull Progression: {', '.join([f'{root} {chord_type}' for root, chord_type in chord_progression])}\n"
            
            self.output_box.config(state=tk.NORMAL)
            self.output_box.delete(1.0, tk.END)
            self.output_box.insert(tk.END, output_text)
            self.output_box.config(state=tk.DISABLED)
        
        except ValueError as e:
            messagebox.showerror("Error", f"Invalid input: {e}")
        except Exception as e:
            messagebox.showerror("Error", f"An error occurred: {e}")
    
    def play(self) -> None:
        """Play the last generated music sequence with BPM control."""
        if not self.last_generated_notes:
            messagebox.showwarning("Warning", "Please generate music first before playing.")
            return
        
        try:
            bpm = int(self.bpm_entry.get())
            if bpm <= 0:
                messagebox.showerror("Error", "BPM must be greater than 0.")
                return
            play_notes(self.last_generated_notes, bpm=bpm)
        except ValueError:
            messagebox.showerror("Error", "BPM must be a valid integer.")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to play audio: {e}")
    
    def play_chord(self) -> None:
        """Play a chord based on selected root and type."""
        try:
            root = self.chord_root_var.get()
            chord_type = self.chord_type_var.get()
            bpm = int(self.bpm_entry.get())
            
            if bpm <= 0:
                messagebox.showerror("Error", "BPM must be greater than 0.")
                return
            
            frequencies = build_chord(root, chord_type)
            audio_data = generate_chord_tone(frequencies, bpm=bpm)
            play_audio(audio_data)
            
            # Display chord info
            chord_notes = []
            root_idx = NOTE_TO_INDEX[root]
            for interval in CHORDS[chord_type]:
                note_idx = (root_idx + interval) % len(NOTES)
                chord_notes.append(INDEX_TO_NOTE[note_idx])
            
            self.output_box.config(state=tk.NORMAL)
            self.output_box.insert(tk.END, f"\n{root} {chord_type}: {', '.join(chord_notes)}")
            self.output_box.config(state=tk.DISABLED)
        except Exception as e:
            messagebox.showerror("Error", f"Failed to play chord: {e}")
    
    def random_seed(self) -> None:
        """Generate a random seed with specified count."""
        try:
            count = int(self.random_count_entry.get())
            if count <= 0:
                messagebox.showerror("Error", "Random seed count must be greater than 0.")
                return
            
            random_notes = generate_random_seed(count, 0)
            random_note_names = [INDEX_TO_NOTE[note] for note in random_notes]
            seed_str = ",".join(random_note_names)
            
            # Update the seed entry field
            self.seed_entry.delete(0, tk.END)
            self.seed_entry.insert(0, seed_str)
            
            # Display in output
            self.output_box.config(state=tk.NORMAL)
            self.output_box.delete(1.0, tk.END)
            self.output_box.insert(tk.END, f"Random Seed Generated ({count} notes):\n{seed_str}\n")
            self.output_box.config(state=tk.DISABLED)
        except ValueError:
            messagebox.showerror("Error", "Random seed count must be a valid integer.")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to generate random seed: {e}")
    
    def play_chord_progression_auto(self) -> None:
        """Play chord progression automatically derived from generated seed."""
        if not self.last_generated_notes:
            messagebox.showwarning("Warning", "Please generate music first before playing chord progression.")
            return
        
        try:
            chord_interval = int(self.chord_interval_entry.get())
            bpm = int(self.bpm_entry.get())
            
            if bpm <= 0:
                messagebox.showerror("Error", "BPM must be greater than 0.")
                return
            
            # Generate audio for chord progression with BPM
            audio_data = play_chord_progression_from_notes(self.last_generated_notes, chord_interval, bpm=bpm)
            play_audio(audio_data)
            
            # Display chord info
            chord_progression = generate_chord_progression_from_seed(self.last_generated_notes, chord_interval)
            chord_names = [f"{root}{chord_type[0].upper()}" for root, chord_type in chord_progression]
            
            self.output_box.config(state=tk.NORMAL)
            self.output_box.insert(tk.END, f"\n\nPlaying Chord Progression @ {bpm} BPM: {' → '.join(chord_names)}\n")
            self.output_box.config(state=tk.DISABLED)
        except ValueError:
            messagebox.showerror("Error", "Chord interval must be a valid integer.")
        except Exception as e:
            messagebox.showerror("Error", f"Failed to play chord progression: {e}")


def main() -> None:
    root = tk.Tk()
    gui = MusicAIGUI(root)
    root.mainloop()


if __name__ == "__main__":
    main()

