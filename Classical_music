import argparse
import random
from typing import Dict, List, Optional, Sequence

import numpy as np


NOTES = ["C", "D", "E", "F", "G", "A", "B"]
NOTE_TO_INDEX = {note: idx for idx, note in enumerate(NOTES)}
INDEX_TO_NOTE = {idx: note for note, idx in NOTE_TO_INDEX.items()}


def encode_window(window: Sequence[int]) -> np.ndarray:
    return np.array(window, dtype=int)


class Neuron:
    def __init__(self) -> None:
        self.features: Optional[np.ndarray] = None
        self.probabilities: Dict[int, float] = {}
        self.occupied = False

    def match(self, input_features: np.ndarray) -> bool:
        if self.features is None:
            return False
        return np.array_equal(self.features, input_features)

    def update_probability(self, class_label: int, success: bool = True) -> None:
        if class_label not in self.probabilities:
            self.probabilities[class_label] = 0.5
        if success:
            self.probabilities[class_label] *= 1.1
        else:
            self.probabilities[class_label] *= 0.9

        total = sum(self.probabilities.values())
        for key in self.probabilities:
            self.probabilities[key] /= total


class MusicMemoryAI:
    def __init__(self, num_neurons: int = 256, window: int = 4) -> None:
        self.window = window
        self.neurons = [Neuron() for _ in range(num_neurons)]

    def train(self, input_features: np.ndarray, class_label: int) -> None:
        matched = False

        for neuron_instance in self.neurons:
            if neuron_instance.occupied and neuron_instance.match(input_features):
                neuron_instance.update_probability(class_label, success=True)
                matched = True
                break

        if not matched:
            for neuron_instance in self.neurons:
                if not neuron_instance.occupied:
                    neuron_instance.features = input_features
                    neuron_instance.occupied = True
                    neuron_instance.update_probability(class_label, success=True)
                    break

    def predict(self, input_features: np.ndarray) -> Optional[int]:
        votes: Dict[int, float] = {}
        for neuron_instance in self.neurons:
            if neuron_instance.features is None:
                continue
            similarity = np.sum(neuron_instance.features == input_features) / len(
                input_features
            )
            if similarity == 0:
                continue
            for class_label, prob in neuron_instance.probabilities.items():
                votes[class_label] = votes.get(class_label, 0.0) + prob * similarity
        if votes:
            return max(votes, key=votes.get)
        return None

    def generate(self, seed: Sequence[int], length: int) -> List[int]:
        if len(seed) < self.window:
            raise ValueError("Seed must be at least the window length.")
        output = list(seed)
        for _ in range(length):
            window = encode_window(output[-self.window :])
            prediction = self.predict(window)
            if prediction is None:
                prediction = random.choice(list(NOTE_TO_INDEX.values()))
            output.append(prediction)
        return output


def build_training_corpus() -> List[List[int]]:
    scale_up = [0, 1, 2, 3, 4, 5, 6]
    scale_down = list(reversed(scale_up))
    arpeggio = [0, 2, 4, 2, 0, 2, 4, 2]
    cadence = [4, 3, 2, 1, 0, 4, 3, 2, 1, 0]
    simple_motif = [0, 1, 0, 2, 0, 3, 0, 4]

    return [
        scale_up * 2,
        scale_down * 2,
        arpeggio,
        cadence,
        simple_motif,
    ]


def train_model(ai: MusicMemoryAI, sequences: List[List[int]]) -> None:
    for seq in sequences:
        for idx in range(ai.window, len(seq)):
            window = encode_window(seq[idx - ai.window : idx])
            label = seq[idx]
            ai.train(window, label)


def parse_seed(seed_notes: str, window: int) -> List[int]:
    tokens = [token.strip().upper() for token in seed_notes.split(",") if token.strip()]
    if not tokens:
        default_seed = [0, 1, 2, 3][:window]
        return default_seed
    return [NOTE_TO_INDEX[token] for token in tokens]


def format_notes(notes: Sequence[int]) -> str:
    return " ".join(INDEX_TO_NOTE[note] for note in notes)


def main() -> None:
    parser = argparse.ArgumentParser(
        description="Generate a simple classical-style melody using a memory-based AI."
    )
    parser.add_argument("--length", type=int, default=16, help="Notes to generate.")
    parser.add_argument(
        "--seed",
        type=str,
        default="C,D,E,F",
        help="Comma-separated seed notes (e.g. C,D,E,F).",
    )
    parser.add_argument("--window", type=int, default=4, help="Context window size.")
    args = parser.parse_args()

    ai = MusicMemoryAI(num_neurons=256, window=args.window)
    corpus = build_training_corpus()
    train_model(ai, corpus)

    seed = parse_seed(args.seed, args.window)
    generated = ai.generate(seed, args.length)
    print("Seed:", format_notes(seed))
    print("Generated:", format_notes(generated))


if __name__ == "__main__":
    main()
